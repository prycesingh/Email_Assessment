# ── Database ────────────────────────────────────────────────────────────────
# Option A: single connection URL
# DATABASE_URL=mysql://user:password@host:3306/dbname

# Option B: individual components (used if DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=email_assessment

# ── Application ──────────────────────────────────────────────────────────────
APP_BASE_URL=https://your-domain.com
AUTH_SECRET=generate-a-strong-random-secret-here
AUTH_URL=https://your-domain.com

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_EVALUATION_MODEL=gpt-4o-mini

# Optional: cost tracking (values in USD cents per 1M tokens)
# OPENAI_INPUT_COST_PER_1M_TOKENS_CENTS=15
# OPENAI_OUTPUT_COST_PER_1M_TOKENS_CENTS=60

# ── Authorization ────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that receive the "admin" role.
# The external API gateway must inject:
#   X-User-Id    — user's unique ID
#   X-User-Email — user's email address
#   X-User-Name  — user's display name (optional)
#
# Leave ADMIN_EMAILS blank to disable admin portal access entirely.
# Example: ADMIN_EMAILS=alice@company.com,bob@company.com
ADMIN_EMAILS=
